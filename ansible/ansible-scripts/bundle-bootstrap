detect_dnf_releasever_major() {
  # Mirrorlist repos on Rocky/RHEL-family typically expect the major version (e.g. 10),
  # but /etc/os-release VERSION_ID can include a minor (e.g. 10.1). If dnf uses 10.1
  # as $releasever, some mirrorlists return empty and installs fail with:
  #   "No URLs in mirrorlist"
  major=""
  if [ -f /etc/os-release ]; then
    # shellcheck disable=SC1091
    . /etc/os-release || true
    if [ -n "${VERSION_ID:-}" ]; then
      major="${VERSION_ID%%.*}"
    fi
  fi
  if printf '%s' "${major}" | grep -Eq '^[0-9]+$'; then
    printf '%s' "${major}"
    return 0
  fi
  return 1
}

ensure_dnf_releasever_major() {
  major="$(detect_dnf_releasever_major || true)"
  if [ -z "${major}" ]; then
    return 0
  fi
  mkdir -p /etc/dnf/vars
  current="$(cat /etc/dnf/vars/releasever 2>/dev/null || true)"
  if [ "${current}" = "${major}" ]; then
    return 0
  fi
  echo "[BOOTSTRAP] Writing /etc/dnf/vars/releasever=${major} (was: ${current:-<unset>})"
  printf '%s\n' "${major}" >/etc/dnf/vars/releasever
}

