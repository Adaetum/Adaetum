# Both break-glass and join nodes fetch the same secret-bearing first-boot
# payload. Phase 99 removes the break-glass copies, but join nodes deliberately
# skip that phase. Remove the files at the successful outer boundary as well so
# a completed node cannot retain stale provider, source-repository, or
# enrollment credentials. Failed runs keep them so the explicit resume path can
# diagnose and retry the incomplete installation.
remove_first_boot_env_files() {
  local path=""
  for path in \
    "${BOOTSTRAP_RUNTIME_ENV_FILE:-/etc/bootstrap-runtime.env}" \
    /etc/ansible-bundle-bootstrap.env \
    /etc/tailscale-firstboot.env; do
    if [ ! -e "${path}" ]; then
      continue
    fi
    if command -v shred >/dev/null 2>&1; then
      shred -u -- "${path}" 2>/dev/null || rm -f -- "${path}"
    else
      rm -f -- "${path}"
    fi
    if [ -e "${path}" ]; then
      echo "[BOOTSTRAP] failed to remove first-boot credential file: ${path}" >&2
      return 1
    fi
    echo "[BOOTSTRAP] removed first-boot credential file: ${path}"
  done
}

