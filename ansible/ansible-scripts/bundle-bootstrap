#!/bin/bash
set -Eeuo pipefail

env_file="/etc/ansible-bundle-bootstrap.env"
if [ -f "${env_file}" ]; then
  set -a
  . "${env_file}"
  set +a
fi
homebrew_shellenv="/etc/profile.d/homebrew.sh"
if [ -f "${homebrew_shellenv}" ]; then
  # shellcheck disable=SC1090
  . "${homebrew_shellenv}"
fi
hash -r 2>/dev/null || true

BOOTSTRAP_PLAYBOOK="${BOOTSTRAP_PLAYBOOK:-/opt/ansible-runner/ansible/playbooks/bootstrap.yml}"
BOOTSTRAP_BREAKGLASS="${BOOTSTRAP_BREAKGLASS:-1}"
BOOTSTRAP_RUN_PHASE40="${BOOTSTRAP_RUN_PHASE40:-}"
BOOTSTRAP_RUN_PHASE50="${BOOTSTRAP_RUN_PHASE50:-}"
BOOTSTRAP_RUN_PHASE60="${BOOTSTRAP_RUN_PHASE60:-}"
BOOTSTRAP_RUN_PHASE70="${BOOTSTRAP_RUN_PHASE70:-}"
BOOTSTRAP_RUN_PHASE90="${BOOTSTRAP_RUN_PHASE90:-}"
BOOTSTRAP_RUN_PHASE99="${BOOTSTRAP_RUN_PHASE99:-}"
BOOTSTRAP_BREAKGLASS_STRICT="${BOOTSTRAP_BREAKGLASS_STRICT:-1}"
export BOOTSTRAP_BREAKGLASS_STRICT

bootstrap_mode_raw="$(printf '%s' "${BOOTSTRAP_BREAKGLASS}" | tr '[:upper:]' '[:lower:]')"
bootstrap_mode_is_breakglass=0
if [ "${bootstrap_mode_raw}" = "1" ] || [ "${bootstrap_mode_raw}" = "true" ] || [ "${bootstrap_mode_raw}" = "yes" ] || [ "${bootstrap_mode_raw}" = "on" ]; then
  bootstrap_mode_is_breakglass=1
fi

# Phase defaults depend on mode:
# - break-glass bootstrap node: run full phase chain by default.
# - join node: only run bootstrap playbook by default; skip phase40/50/60/70 unless explicitly enabled.
if [ -z "${BOOTSTRAP_RUN_PHASE40}" ]; then
  if [ "${bootstrap_mode_is_breakglass}" -eq 1 ]; then BOOTSTRAP_RUN_PHASE40=1; else BOOTSTRAP_RUN_PHASE40=0; fi
fi
if [ -z "${BOOTSTRAP_RUN_PHASE50}" ]; then
  if [ "${bootstrap_mode_is_breakglass}" -eq 1 ]; then BOOTSTRAP_RUN_PHASE50=1; else BOOTSTRAP_RUN_PHASE50=0; fi
fi
if [ -z "${BOOTSTRAP_RUN_PHASE60}" ]; then
  if [ "${bootstrap_mode_is_breakglass}" -eq 1 ]; then BOOTSTRAP_RUN_PHASE60=1; else BOOTSTRAP_RUN_PHASE60=0; fi
fi
if [ -z "${BOOTSTRAP_RUN_PHASE70}" ]; then
  if [ "${bootstrap_mode_is_breakglass}" -eq 1 ]; then BOOTSTRAP_RUN_PHASE70=1; else BOOTSTRAP_RUN_PHASE70=0; fi
fi
if [ -z "${BOOTSTRAP_RUN_PHASE90}" ]; then
  if [ "${bootstrap_mode_is_breakglass}" -eq 1 ]; then BOOTSTRAP_RUN_PHASE90=1; else BOOTSTRAP_RUN_PHASE90=0; fi
fi
if [ -z "${BOOTSTRAP_RUN_PHASE99}" ]; then
  if [ "${bootstrap_mode_is_breakglass}" -eq 1 ]; then BOOTSTRAP_RUN_PHASE99=1; else BOOTSTRAP_RUN_PHASE99=0; fi
fi

# Join mode must not execute bootstrap-node phases. These phases are for the
# cluster primary (OpenBao/Routing/Burn/health validation on primary), not joiners.
if [ "${bootstrap_mode_is_breakglass}" -eq 0 ]; then
  BOOTSTRAP_RUN_PHASE40=0
  BOOTSTRAP_RUN_PHASE50=0
  BOOTSTRAP_RUN_PHASE60=0
  BOOTSTRAP_RUN_PHASE70=0
  BOOTSTRAP_RUN_PHASE90=0
  BOOTSTRAP_RUN_PHASE99=0
fi

log_file="${BUNDLE_BOOTSTRAP_LOG_FILE:-/var/log/ansible-bundle-bootstrap.log}"
export BUNDLE_BOOTSTRAP_LOG_FILE="${log_file}"
phase_log_dir="${BOOTSTRAP_PHASE_LOG_DIR:-$(dirname "${log_file}")/bootstrap-phases}"
mkdir -p "${phase_log_dir}"
export BOOTSTRAP_PHASE_LOG_DIR="${phase_log_dir}"
BOOTSTRAP_PHASE_STATUS_FILE="${BOOTSTRAP_PHASE_STATUS_FILE:-/run/bootstrap-phase-status.env}"
export BOOTSTRAP_PHASE_STATUS_FILE
BOOTSTRAP_PROGRESS_RUN_STARTED_AT="$(date +%s)"
BOOTSTRAP_PROGRESS_CURRENT_PHASE_KEY=""
BOOTSTRAP_PROGRESS_CURRENT_PHASE_STARTED_AT=""
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/bootstrap" && pwd -P)"
# shellcheck disable=SC1091
. "${script_dir}/diagnostics.sh"
bootstrap_diag_init
echo "[BOOTSTRAP] diagnostics jsonl -> ${BOOTSTRAP_DIAGNOSTICS_JSONL}"
echo "[BOOTSTRAP] diagnostics artifacts -> ${BOOTSTRAP_DIAGNOSTICS_RUN_DIR}"
if [ "${BUNDLE_BOOTSTRAP_LOG_INIT:-1}" != "0" ]; then
  mkdir -p "$(dirname "${log_file}")"
  : > "${log_file}"
  if command -v stdbuf >/dev/null 2>&1; then
    # Keep the logging pipe open even if tee fails (e.g. disk full) to avoid SIGPIPE exits.
    exec > >(stdbuf -oL tee "${log_file}" || cat >/dev/null) 2>&1
  else
    exec > >(tee "${log_file}" || cat >/dev/null) 2>&1
  fi
fi

phase_log_path() {
  local key="${1:?key}"
  printf '%s/%s.log\n' "${phase_log_dir}" "${key}"
}

phase_position_for_id() {
  case "${1:-}" in
    10) printf '1' ;;
    20) printf '2' ;;
    30) printf '3' ;;
    40) printf '4' ;;
    50) printf '5' ;;
    60) printf '6' ;;
    70) printf '7' ;;
    90) printf '8' ;;
    99) printf '9' ;;
    100) printf '10' ;;
    *) printf '0' ;;
  esac
}

phase_label_for_id() {
  case "${1:-}" in
    10) printf 'fast-fail validation gate' ;;
    20) printf 'bootstrap-local secret authority' ;;
    30) printf 'platform bootstrap' ;;
    40) printf 'OpenBao authority transition' ;;
    50) printf 'minimal Argo CD + Gitea install' ;;
    60) printf 'repo seed + GitOps handoff' ;;
    70) printf 'GitOps realization gate' ;;
    90) printf 'late live-state reconciliation' ;;
    99) printf 'recovery export + destroy bootstrap authority' ;;
    100) printf 'final result' ;;
    *) printf 'pre-bootstrap' ;;
  esac
}

bootstrap_phase_status_write() {
  local phase_id="${1:-0}"
  local phase_key="${2:-pre-bootstrap}"
  local phase_state="${3:-STARTING}"
  local phase_label="${4:-}"
  local phase_detail="${5:-}"
  local phase_log_path="${6:-}"
  local phase_total="10"
  local phase_position=""
  local status_dir=""
  local tmp_file=""
  local now=""

  now="$(date +%s)"
  if [ "${BOOTSTRAP_PROGRESS_CURRENT_PHASE_KEY}" != "${phase_key}" ]; then
    BOOTSTRAP_PROGRESS_CURRENT_PHASE_KEY="${phase_key}"
    BOOTSTRAP_PROGRESS_CURRENT_PHASE_STARTED_AT="${now}"
  fi

  phase_position="$(phase_position_for_id "${phase_id}")"
  if [ -z "${phase_label}" ]; then
    phase_label="$(phase_label_for_id "${phase_id}")"
  fi
  if [ -z "${phase_detail}" ]; then
    case "${phase_state}" in
      RUNNING|STARTING) phase_detail="Running ${phase_label}" ;;
      SUCCESS) phase_detail="Completed ${phase_label}" ;;
      FAILED|ERROR) phase_detail="Failed ${phase_label}" ;;
      *) phase_detail="${phase_label}" ;;
    esac
  fi
  if [ -z "${phase_log_path}" ]; then
    case "${phase_key}" in
      phase20|phase30) phase_log_path="$(phase_log_path "bundle-playbook")" ;;
      pre-bootstrap|phase100) phase_log_path="${log_file}" ;;
      *) phase_log_path="$(phase_log_path "${phase_key}")" ;;
    esac
  fi
  status_dir="$(dirname "${BOOTSTRAP_PHASE_STATUS_FILE}")"
  mkdir -p "${status_dir}"
  tmp_file="$(mktemp "${BOOTSTRAP_PHASE_STATUS_FILE}.tmp.XXXXXX")"
  {
    printf 'BOOTSTRAP_PROGRESS_PHASE_ID=%q\n' "${phase_id}"
    printf 'BOOTSTRAP_PROGRESS_PHASE_KEY=%q\n' "${phase_key}"
    printf 'BOOTSTRAP_PROGRESS_PHASE_POSITION=%q\n' "${phase_position}"
    printf 'BOOTSTRAP_PROGRESS_PHASE_TOTAL=%q\n' "${phase_total}"
    printf 'BOOTSTRAP_PROGRESS_PHASE_STATE=%q\n' "${phase_state}"
    printf 'BOOTSTRAP_PROGRESS_PHASE_LABEL=%q\n' "${phase_label}"
    printf 'BOOTSTRAP_PROGRESS_PHASE_DETAIL=%q\n' "${phase_detail}"
    printf 'BOOTSTRAP_PROGRESS_PHASE_LOG_PATH=%q\n' "${phase_log_path}"
    printf 'BOOTSTRAP_PROGRESS_PHASE_STARTED_AT=%q\n' "${BOOTSTRAP_PROGRESS_CURRENT_PHASE_STARTED_AT}"
    printf 'BOOTSTRAP_PROGRESS_UPDATED_AT=%q\n' "${now}"
    printf 'BOOTSTRAP_PROGRESS_RUN_STARTED_AT=%q\n' "${BOOTSTRAP_PROGRESS_RUN_STARTED_AT}"
  } > "${tmp_file}"
  mv -f "${tmp_file}" "${BOOTSTRAP_PHASE_STATUS_FILE}"
}

bootstrap_phase_status_reset() {
  bootstrap_phase_status_write "0" "pre-bootstrap" "STARTING" "pre-bootstrap"
}

is_true() {
  case "${1:-}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

# shellcheck disable=SC1091
. "${script_dir}/phase-state.sh"

BOOTSTRAP_SKIP_DONE="${BOOTSTRAP_SKIP_DONE:-1}"
BOOTSTRAP_FORCE="${BOOTSTRAP_FORCE:-0}"
BOOTSTRAP_RESET_STATE="${BOOTSTRAP_RESET_STATE:-0}"
if is_true "${BOOTSTRAP_BREAKGLASS_STRICT}"; then
  # Break-glass first boot should always run phases instead of trusting stale done markers.
  BOOTSTRAP_SKIP_DONE=0
fi

should_skip() {
  local key="${1:?key}"
  if is_true "${BOOTSTRAP_FORCE}"; then
    return 1
  fi
  if ! is_true "${BOOTSTRAP_SKIP_DONE}"; then
    return 1
  fi
  bootstrap_state_has "${key}"
}

mark_done() {
  local key="${1:?key}"
  bootstrap_state_mark "${key}"
}

run_step() {
  local key="${1:?key}"
  shift
  local label="${1:?label}"
  shift

  if should_skip "${key}"; then
    echo "[BOOTSTRAP] ${label}: skip (done marker present)"
    return 0
  fi

  echo "[BOOTSTRAP] ${label}: start"
  local step_log
  step_log="$(phase_log_path "${key}")"
  : > "${step_log}"
  echo "[BOOTSTRAP] ${label}: phase log -> ${step_log}"
  local start_ts
  start_ts="$(date +%s)"
  bootstrap_diag_record \
    "phase=${key}" \
    "step=${key}" \
    "component=bundle-bootstrap" \
    "operation=step-start" \
    "severity=info" \
    "summary=${label}: start" \
    "log_path=${step_log}"
  if command -v stdbuf >/dev/null 2>&1; then
    "$@" > >(stdbuf -oL tee -a "${step_log}") 2> >(stdbuf -oL tee -a "${step_log}" >&2)
  else
    "$@" > >(tee -a "${step_log}") 2> >(tee -a "${step_log}" >&2)
  fi
  local rc=$?
  local end_ts
  end_ts="$(date +%s)"
  local dur
  dur="$((end_ts - start_ts))"
  if [ "${rc}" -eq 0 ]; then
    mark_done "${key}"
    echo "[BOOTSTRAP] ${label}: ok (${dur}s)"
    bootstrap_diag_record \
      "phase=${key}" \
      "step=${key}" \
      "component=bundle-bootstrap" \
      "operation=step-complete" \
      "severity=info" \
      "exit_code=0" \
      "duration_seconds=${dur}" \
      "summary=${label}: ok" \
      "log_path=${step_log}"
  else
    local tail_excerpt=""
    if [ -f "${step_log}" ]; then
      echo "[BOOTSTRAP] ${label}: phase log tail (last 80 lines)"
      tail_excerpt="$(tail -n 80 "${step_log}" 2>/dev/null || true)"
      printf '%s\n' "${tail_excerpt}"
    fi
    echo "[BOOTSTRAP] ${label}: failed rc=${rc} (${dur}s)" >&2
    bootstrap_diag_record \
      "phase=${key}" \
      "step=${key}" \
      "component=bundle-bootstrap" \
      "operation=step-failed" \
      "severity=error" \
      "exit_code=${rc}" \
      "duration_seconds=${dur}" \
      "failure_kind=$(bootstrap_diag_classify_failure_kind "${tail_excerpt}")" \
      "summary=${label}: failed rc=${rc}" \
      "stderr_excerpt=${tail_excerpt}" \
      "log_path=${step_log}"
  fi
  return "${rc}"
}

run_bootstrap_phase() {
  local phase_id="${1:?phase_id}"
  local key="${2:?key}"
  shift 2
  local label="${1:?label}"
  shift
  bootstrap_phase_status_write "${phase_id}" "${key}" "RUNNING" "$(phase_label_for_id "${phase_id}")"
  if run_step "${key}" "${label}" "$@"; then
    bootstrap_phase_status_write "${phase_id}" "${key}" "SUCCESS" "$(phase_label_for_id "${phase_id}")"
    return 0
  fi
  local rc=$?
  bootstrap_phase_status_write "${phase_id}" "${key}" "FAILED" "$(phase_label_for_id "${phase_id}")"
  return "${rc}"
}

run_bootstrap_playbook_phases() {
  local key="bundle-playbook"
  local label="run bootstrap playbook"
  local step_log=""
  local start_ts=""
  local end_ts=""
  local dur=""
  local rc=0
  local phase20_log=""
  local phase30_log=""
  local phase30_seen_file=""
  local phase30_marker_1="TASK [Ensure base packages are installed on RedHat family]"
  local phase30_marker_2="TASK [Ensure base packages are installed on non-RedHat families]"

  if should_skip "${key}"; then
    echo "[BOOTSTRAP] ${label}: skip (done marker present)"
    bootstrap_phase_status_write "30" "phase30" "SUCCESS" "$(phase_label_for_id "30")"
    return 0
  fi

  echo "[BOOTSTRAP] ${label}: start"
  step_log="$(phase_log_path "${key}")"
  : > "${step_log}"
  echo "[BOOTSTRAP] ${label}: phase log -> ${step_log}"
  start_ts="$(date +%s)"
  bootstrap_phase_status_write "20" "phase20" "RUNNING" "$(phase_label_for_id "20")"
  bootstrap_diag_record \
    "phase=${key}" \
    "step=${key}" \
    "component=bundle-bootstrap" \
    "operation=step-start" \
    "severity=info" \
    "summary=${label}: start" \
    "log_path=${step_log}"

  phase30_seen_file="$(mktemp)"
  (
    while true; do
      if [ -f "${step_log}" ] && { grep -Fq "${phase30_marker_1}" "${step_log}" || grep -Fq "${phase30_marker_2}" "${step_log}"; }; then
        printf '1\n' > "${phase30_seen_file}"
        bootstrap_phase_status_write "30" "phase30" "RUNNING" "$(phase_label_for_id "30")"
        break
      fi
      if [ -n "${BUNDLE_PLAYBOOK_PID:-}" ] && ! kill -0 "${BUNDLE_PLAYBOOK_PID}" 2>/dev/null; then
        break
      fi
      sleep 1
    done
  ) &
  local phase30_monitor_pid=$!

  set +e
  if command -v stdbuf >/dev/null 2>&1; then
    bash -lc '
      echo "[BOOTSTRAP] Running Ansible bootstrap playbook"
      cd /opt/ansible-runner/ansible
      export ANSIBLE_CONFIG="/opt/ansible-runner/ansible/ansible.cfg"
      export ANSIBLE_ROLES_PATH="/opt/ansible-runner/ansible/automation-roles:/opt/ansible-runner/ansible/playbooks/roles:/etc/ansible/roles:/usr/share/ansible/roles"
      mode_raw="$(printf "%s" "${BOOTSTRAP_BREAKGLASS:-1}" | tr "[:upper:]" "[:lower:]")"
      if [ -z "${BOOTSTRAP_JOIN_REQUIRED+x}" ] || [ -z "${BOOTSTRAP_JOIN_REQUIRED}" ]; then
        join_required_raw="1"
      else
        join_required_raw="$(printf "%s" "${BOOTSTRAP_JOIN_REQUIRED}" | tr "[:upper:]" "[:lower:]")"
      fi
      if [ "${mode_raw}" = "1" ] || [ "${mode_raw}" = "true" ] || [ "${mode_raw}" = "yes" ] || [ "${mode_raw}" = "on" ]; then
        echo "[BOOTSTRAP] mode=break-glass (local bootstrap node is cluster primary)"
        ansible-playbook -i /opt/ansible-runner/ansible/node-inventory.yml "${BOOTSTRAP_PLAYBOOK}" -e break_glass=true
      else
        echo "[BOOTSTRAP] mode=join (local bootstrap node joins existing cluster based on Tailscale inventory/tags)"
        echo "[BOOTSTRAP] strict join required: ${join_required_raw}"
        ansible-playbook -i /opt/ansible-runner/ansible/node-inventory.yml "${BOOTSTRAP_PLAYBOOK}" -e break_glass=true -e break_glass_cluster_join=true -e break_glass_join_required="${join_required_raw}"
      fi
    ' > >(stdbuf -oL tee -a "${step_log}") 2> >(stdbuf -oL tee -a "${step_log}" >&2) &
  else
    bash -lc '
      echo "[BOOTSTRAP] Running Ansible bootstrap playbook"
      cd /opt/ansible-runner/ansible
      export ANSIBLE_CONFIG="/opt/ansible-runner/ansible/ansible.cfg"
      export ANSIBLE_ROLES_PATH="/opt/ansible-runner/ansible/automation-roles:/opt/ansible-runner/ansible/playbooks/roles:/etc/ansible/roles:/usr/share/ansible/roles"
      mode_raw="$(printf "%s" "${BOOTSTRAP_BREAKGLASS:-1}" | tr "[:upper:]" "[:lower:]")"
      if [ -z "${BOOTSTRAP_JOIN_REQUIRED+x}" ] || [ -z "${BOOTSTRAP_JOIN_REQUIRED}" ]; then
        join_required_raw="1"
      else
        join_required_raw="$(printf "%s" "${BOOTSTRAP_JOIN_REQUIRED}" | tr "[:upper:]" "[:lower:]")"
      fi
      if [ "${mode_raw}" = "1" ] || [ "${mode_raw}" = "true" ] || [ "${mode_raw}" = "yes" ] || [ "${mode_raw}" = "on" ]; then
        echo "[BOOTSTRAP] mode=break-glass (local bootstrap node is cluster primary)"
        ansible-playbook -i /opt/ansible-runner/ansible/node-inventory.yml "${BOOTSTRAP_PLAYBOOK}" -e break_glass=true
      else
        echo "[BOOTSTRAP] mode=join (local bootstrap node joins existing cluster based on Tailscale inventory/tags)"
        echo "[BOOTSTRAP] strict join required: ${join_required_raw}"
        ansible-playbook -i /opt/ansible-runner/ansible/node-inventory.yml "${BOOTSTRAP_PLAYBOOK}" -e break_glass=true -e break_glass_cluster_join=true -e break_glass_join_required="${join_required_raw}"
      fi
    ' > >(tee -a "${step_log}") 2> >(tee -a "${step_log}" >&2) &
  fi
  BUNDLE_PLAYBOOK_PID=$!
  wait "${BUNDLE_PLAYBOOK_PID}"
  rc=$?
  unset BUNDLE_PLAYBOOK_PID
  set -e

  wait "${phase30_monitor_pid}" 2>/dev/null || true
  split_bundle_playbook_phase_logs

  if [ "${rc}" -eq 0 ]; then
    mark_done "${key}"
    if [ -s "${phase30_seen_file}" ]; then
      bootstrap_phase_status_write "30" "phase30" "SUCCESS" "$(phase_label_for_id "30")"
    else
      bootstrap_phase_status_write "20" "phase20" "SUCCESS" "$(phase_label_for_id "20")"
      bootstrap_phase_status_write "30" "phase30" "SUCCESS" "$(phase_label_for_id "30")"
    fi
    end_ts="$(date +%s)"
    dur="$((end_ts - start_ts))"
    echo "[BOOTSTRAP] ${label}: ok (${dur}s)"
    bootstrap_diag_record \
      "phase=${key}" \
      "step=${key}" \
      "component=bundle-bootstrap" \
      "operation=step-complete" \
      "severity=info" \
      "exit_code=0" \
      "duration_seconds=${dur}" \
      "summary=${label}: ok" \
      "log_path=${step_log}"
    rm -f "${phase30_seen_file}" 2>/dev/null || true
    return 0
  fi

  end_ts="$(date +%s)"
  dur="$((end_ts - start_ts))"
  local tail_excerpt=""
  if [ -f "${step_log}" ]; then
    echo "[BOOTSTRAP] ${label}: phase log tail (last 80 lines)"
    tail_excerpt="$(tail -n 80 "${step_log}" 2>/dev/null || true)"
    printf '%s\n' "${tail_excerpt}"
  fi
  if [ -s "${phase30_seen_file}" ]; then
    bootstrap_phase_status_write "30" "phase30" "FAILED" "$(phase_label_for_id "30")"
  else
    bootstrap_phase_status_write "20" "phase20" "FAILED" "$(phase_label_for_id "20")"
  fi
  echo "[BOOTSTRAP] ${label}: failed rc=${rc} (${dur}s)" >&2
  bootstrap_diag_record \
    "phase=${key}" \
    "step=${key}" \
    "component=bundle-bootstrap" \
    "operation=step-failed" \
    "severity=error" \
    "exit_code=${rc}" \
    "duration_seconds=${dur}" \
    "failure_kind=$(bootstrap_diag_classify_failure_kind "${tail_excerpt}")" \
    "summary=${label}: failed rc=${rc}" \
    "stderr_excerpt=${tail_excerpt}" \
    "log_path=${step_log}"
  rm -f "${phase30_seen_file}" 2>/dev/null || true
  return "${rc}"
}

split_bundle_playbook_phase_logs() {
  local source_log
  source_log="$(phase_log_path "bundle-playbook")"
  local phase20_log
  phase20_log="$(phase_log_path "phase20")"
  local phase30_log
  phase30_log="$(phase_log_path "phase30")"

  if [ ! -f "${source_log}" ]; then
    return 0
  fi

  python3 - "${source_log}" "${phase20_log}" "${phase30_log}" <<'PY'
import sys
from pathlib import Path

source_path = Path(sys.argv[1])
phase20_path = Path(sys.argv[2])
phase30_path = Path(sys.argv[3])
lines = source_path.read_text(encoding="utf-8", errors="replace").splitlines()

play_header_idx = None
phase20_start_idx = None
phase30_start_idx = None

phase20_markers = [
    "TASK [Ensure bootstrap secrets directory exists]",
]
phase30_markers = [
    "TASK [Ensure base packages are installed on RedHat family]",
    "TASK [Ensure base packages are installed on non-RedHat families]",
]

for idx, line in enumerate(lines):
    if play_header_idx is None and "PLAY [Platform bootstrap (Phase 30)]" in line:
        play_header_idx = idx
    if phase20_start_idx is None and any(marker in line for marker in phase20_markers):
        phase20_start_idx = idx
    if phase30_start_idx is None and any(marker in line for marker in phase30_markers):
        phase30_start_idx = idx

if play_header_idx is None:
    play_header_idx = 0

if phase20_start_idx is None:
    phase20_start_idx = play_header_idx

phase20_lines = []
phase30_lines = []

if phase20_start_idx is not None:
    phase20_lines.extend(lines[play_header_idx:phase20_start_idx])
    if phase30_start_idx is not None and phase30_start_idx > phase20_start_idx:
        phase20_lines.extend(lines[phase20_start_idx:phase30_start_idx])
    else:
        phase20_lines.extend(lines[phase20_start_idx:])

if phase30_start_idx is not None:
    phase30_lines.extend(lines[play_header_idx:play_header_idx + 2])
    phase30_lines.extend(lines[phase30_start_idx:])

if not phase20_lines:
    phase20_lines = [
        "[BOOTSTRAP] phase20 log extraction did not find a distinct secret-authority block in bundle-playbook.log",
        f"[BOOTSTRAP] source log: {source_path}",
    ]

if not phase30_lines:
    phase30_lines = [
        "[BOOTSTRAP] phase30 log extraction did not find a distinct platform-bootstrap block in bundle-playbook.log",
        f"[BOOTSTRAP] source log: {source_path}",
    ]

phase20_path.write_text("\n".join(phase20_lines) + "\n", encoding="utf-8")
phase30_path.write_text("\n".join(phase30_lines) + "\n", encoding="utf-8")
PY
}

if is_true "${BOOTSTRAP_RESET_STATE}"; then
  echo "[BOOTSTRAP] reset state dir: $(bootstrap_state_dir)"
  bootstrap_state_reset
fi

patch_phase40_script() {
  local phase40="/opt/ansible-runner/ansible/ansible-scripts/bootstrap/Phase-40/run-phase40.sh"
  if [ ! -f "${phase40}" ]; then
    return 0
  fi
  if grep -q "set +o pipefail" "${phase40}"; then
    return 0
  fi
  echo "[BOOTSTRAP] Patching run-phase40.sh to avoid SIGPIPE during Longhorn checks"
  python3 - <<'PY' "${phase40}"
import sys, re

path = sys.argv[1]
text = open(path, "r", encoding="utf-8", errors="replace").read()

def replace_block(text, fn_name, new_body):
    pattern = rf"{fn_name}\\(\\) \\{{.*?^\\}}"
    m = re.search(pattern, text, flags=re.S | re.M)
    if not m:
