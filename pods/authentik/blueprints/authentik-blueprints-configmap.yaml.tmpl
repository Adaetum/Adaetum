apiVersion: v1
kind: ConfigMap
metadata:
  name: authentik-blueprints
  namespace: authentik
data:
  cluster-forward-auth.yaml: |
    version: 1
    metadata:
      name: Cluster - Embedded Outpost Forward Auth
      labels:
        blueprints.goauthentik.io/description: >
          Configures proxy providers for externally exposed cluster apps and assigns
          them to the built-in authentik Embedded Outpost.
    entries:
      - model: authentik_blueprints.metaapplyblueprint
        attrs:
          identifiers:
            name: Default - Authentication flow
          required: false
      - model: authentik_blueprints.metaapplyblueprint
        attrs:
          identifiers:
            name: Default - Provider authorization flow (implicit consent)
          required: false
      - model: authentik_blueprints.metaapplyblueprint
        attrs:
          identifiers:
            name: Default - Provider invalidation flow
          required: false

      - id: argocd-local-provider
        model: authentik_providers_proxy.proxyprovider
        state: present
        identifiers:
          name: cluster-argocd-local-forward-auth
        attrs:
          name: cluster-argocd-local-forward-auth
          mode: forward_domain
          external_host: https://argocd.example.local
          cookie_domain: .example.local
          authentication_flow: !Find [authentik_flows.flow, [slug, default-authentication-flow]]
          authorization_flow: !Find [authentik_flows.flow, [slug, default-provider-authorization-implicit-consent]]
          invalidation_flow: !Find [authentik_flows.flow, [slug, default-provider-invalidation-flow]]
          internal_host_ssl_validation: false
          skip_path_regex: ^/outpost\.goauthentik\.io/.*$

      - model: authentik_core.application
        state: present
        identifiers:
          slug: cluster-argocd-local
        attrs:
          name: Cluster Argo CD (Local)
          slug: cluster-argocd-local
          provider: !KeyOf argocd-local-provider
          meta_launch_url: https://argocd.example.local
          meta_description: Cluster Argo CD access
          policy_engine_mode: any

      - id: argocd-public-provider
