CLUSTER_DOMAIN=mudazukai.cloud
CLUSTER_LOCAL_DOMAIN=mudazukai.local
GITEA_REPO_OWNER=gitea-admin
GITEA_REPO_NAME=cluster
GITEA_PUBLIC_HOST=gitea.mudazukai.cloud
GITEA_LOCAL_HOST=gitea.mudazukai.local
GITEA_CANONICAL_HOST=gitea.mudazukai.local
ARGOCD_PUBLIC_HOST=argocd.mudazukai.cloud
ARGOCD_LOCAL_HOST=argocd.mudazukai.local
OPENBAO_PUBLIC_HOST=openbao.mudazukai.cloud
OPENBAO_LOCAL_HOST=openbao.mudazukai.local
HOMEPAGE_PUBLIC_HOST=home.mudazukai.cloud
HOMEPAGE_LOCAL_HOST=home.mudazukai.local
HOMEPAGE_ALLOWED_HOSTS=home.mudazukai.local,home.mudazukai.cloud,homepage.homepage.svc.cluster.local,homepage.homepage.svc,localhost,127.0.0.1
HEADLAMP_PUBLIC_HOST=headlamp.mudazukai.cloud
HEADLAMP_LOCAL_HOST=headlamp.mudazukai.local
ALERTMANAGER_PUBLIC_HOST=alertmanager.mudazukai.cloud
ALERTMANAGER_LOCAL_HOST=alertmanager.mudazukai.local
GRAFANA_PUBLIC_HOST=grafana.mudazukai.cloud
GRAFANA_LOCAL_HOST=grafana.mudazukai.local
PROMETHEUS_PUBLIC_HOST=prometheus.mudazukai.cloud
PROMETHEUS_LOCAL_HOST=prometheus.mudazukai.local
RANCHER_PUBLIC_HOST=rancher.mudazukai.cloud
RANCHER_LOCAL_HOST=rancher.mudazukai.local
AUTHENTIK_PUBLIC_HOST=authentik.mudazukai.cloud
AUTHENTIK_LOCAL_HOST=authentik.mudazukai.local
AUTHENTIK_FORWARD_AUTH_URL=http://authentik-server.authentik.svc.cluster.local:80/outpost.goauthentik.io/auth/nginx
AUTHENTIK_LOCAL_AUTH_SIGNIN=https://$host/outpost.goauthentik.io/start?rd=$scheme://$http_host$escaped_request_uri
AUTHENTIK_PUBLIC_AUTH_SIGNIN=https://$host/outpost.goauthentik.io/start?rd=$scheme://$http_host$escaped_request_uri
AUTHENTIK_AUTH_RESPONSE_HEADERS=Set-Cookie,X-authentik-username,X-authentik-groups,X-authentik-entitlements,X-authentik-email,X-authentik-name,X-authentik-uid
AUTHENTIK_AUTH_SNIPPET=proxy_set_header X-Forwarded-Host $http_host;
REGISTRY_LOCAL_HOST=registry.mudazukai.local
REGISTRY_PUBLIC_HOST=registry.mudazukai.cloud
ANSIBLE_RUNNER_IMAGE=registry.mudazukai.cloud/gitea-admin/ansible-runner:build-cd29336c14e3c876
TAILSCALE_DOMAIN=armadillo-peacock.ts.net
TAILSCALE_CLUSTER_TAG=tag:cluster
EXTERNAL_DNS_DOMAIN_FILTER=mudazukai.cloud
HOST_MAINTENANCE_ENABLED=true
HOST_MAINTENANCE_REBOOT_ENABLED=true
HOST_MAINTENANCE_REBOOT_DAYS=[su, mo, tu, we, th, fr, sa]
HOST_MAINTENANCE_REBOOT_START_TIME=03:00
HOST_MAINTENANCE_REBOOT_END_TIME=06:00
HOST_MAINTENANCE_TIME_ZONE=America/Chicago
HOST_MAINTENANCE_REBOOT_PERIOD=1h
HOST_MAINTENANCE_CONCURRENCY=1
HOST_MAINTENANCE_DRAIN_TIMEOUT=30m
HOST_MAINTENANCE_DRAIN_GRACE_PERIOD=-1
HOST_MAINTENANCE_FORCE_REBOOT=false
HOST_MAINTENANCE_LOCK_TTL=0
HOST_MAINTENANCE_LOCK_RELEASE_DELAY=10m
HOST_MAINTENANCE_REBOOT_DELAY=0
HOST_MAINTENANCE_BLOCKING_POD_SELECTORS=[]
HOST_MAINTENANCE_PROMETHEUS_URL="http://prometheus-kube-prometheus-prometheus.observability.svc.cluster.local:9090"
HOST_MAINTENANCE_METRICS=true
HOST_MAINTENANCE_ANNOTATE_NODES=true
HOST_MAINTENANCE_SENTINEL_COMMAND="sh -c \"! needs-restarting --reboothint\""
