CLUSTER_DOMAIN=adaetum.invalid
CLUSTER_LOCAL_DOMAIN=adaetum.local
GITEA_REPO_OWNER=gitea-admin
GITEA_REPO_NAME=cluster
GITEA_PUBLIC_HOST=gitea.adaetum.invalid
GITEA_LOCAL_HOST=gitea.adaetum.local
GITEA_CANONICAL_HOST=gitea.adaetum.local
ARGOCD_PUBLIC_HOST=argocd.adaetum.invalid
ARGOCD_LOCAL_HOST=argocd.adaetum.local
OPENBAO_PUBLIC_HOST=openbao.adaetum.invalid
OPENBAO_LOCAL_HOST=openbao.adaetum.local
HOMEPAGE_PUBLIC_HOST=home.adaetum.invalid
HOMEPAGE_LOCAL_HOST=home.adaetum.local
HOMEPAGE_ALLOWED_HOSTS=home.adaetum.local,home.adaetum.invalid,homepage.homepage.svc.cluster.local,homepage.homepage.svc,localhost,127.0.0.1
HEADLAMP_PUBLIC_HOST=headlamp.adaetum.invalid
HEADLAMP_LOCAL_HOST=headlamp.adaetum.local
ALERTMANAGER_PUBLIC_HOST=alertmanager.adaetum.invalid
ALERTMANAGER_LOCAL_HOST=alertmanager.adaetum.local
GRAFANA_PUBLIC_HOST=grafana.adaetum.invalid
GRAFANA_LOCAL_HOST=grafana.adaetum.local
PROMETHEUS_PUBLIC_HOST=prometheus.adaetum.invalid
PROMETHEUS_LOCAL_HOST=prometheus.adaetum.local
RANCHER_PUBLIC_HOST=rancher.adaetum.invalid
AUTHENTIK_PUBLIC_HOST=authentik.adaetum.invalid
AUTHENTIK_LOCAL_HOST=authentik.adaetum.local
AUTHENTIK_FORWARD_AUTH_URL=http://authentik-server.authentik.svc.cluster.local:80/outpost.goauthentik.io/auth/nginx
AUTHENTIK_LOCAL_AUTH_SIGNIN=https://$host/outpost.goauthentik.io/start?rd=$scheme://$http_host$escaped_request_uri
AUTHENTIK_PUBLIC_AUTH_SIGNIN=https://$host/outpost.goauthentik.io/start?rd=$scheme://$http_host$escaped_request_uri
AUTHENTIK_AUTH_RESPONSE_HEADERS=Set-Cookie,X-authentik-username,X-authentik-groups,X-authentik-entitlements,X-authentik-email,X-authentik-name,X-authentik-uid
AUTHENTIK_AUTH_SNIPPET=proxy_set_header X-Forwarded-Host $http_host;
REGISTRY_LOCAL_HOST=registry.adaetum.local
REGISTRY_PUBLIC_HOST=registry.adaetum.invalid
ANSIBLE_RUNNER_IMAGE=registry.adaetum.invalid/gitea-admin/ansible-runner:latest
TAILSCALE_DOMAIN=example-tailnet.ts.net
TAILSCALE_CLUSTER_TAG=tag:cluster
EXTERNAL_DNS_DOMAIN_FILTER=adaetum.invalid
