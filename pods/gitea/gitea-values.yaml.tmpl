podSecurityContext:
  fsGroup: 1000
  fsGroupChangePolicy: OnRootMismatch

# Gitea uses a local level queue on the shared PVC during bootstrap. Keep
# upgrades single-pod so Argo takeover never overlaps two writers.
strategy:
  type: Recreate

persistence:
  enabled: true
  accessModes:
    - ReadWriteOnce
  size: 10Gi
  storageClass: longhorn
  annotations:
    helm.sh/resource-policy: keep

# The recovery mirror hook reads this projected delivery Secret for every
# push. External Secrets refreshes it from OpenBao, so provider-token rotation
# never writes a credential into the repository PVC or requires a pod restart.
extraVolumes:
  - name: push-mirror-credential
    secret:
      secretName: gitea-push-mirror
      optional: true
      items:
        - key: remote_url
          path: remote_url
        - key: username
          path: username
        - key: token
          path: token
extraContainerVolumeMounts:
  - name: push-mirror-credential
    mountPath: /var/run/adaetum/push-mirror
    readOnly: true

# Make the bundled database persistence explicit as part of the desired state.
# Do not rely on chart defaults for data retention.
postgresql-ha:
  enabled: false

postgresql:
  enabled: true
  persistence:
    enabled: true
    size: 10Gi
    storageClass: longhorn
    annotations:
      helm.sh/resource-policy: keep

ingress:
  # Disabled: routing is handled by nginx Ingress manifests in pods/ingress.
  enabled: false

# Bootstrap sets the live canonical URL from CLUSTER_DOMAIN / CLUSTER_LOCAL_DOMAIN.
# Keep these aligned with the Phase 50 local bootstrap install so Argo takeover
# is a no-op instead of rolling Gitea onto a different inline config secret.
gitea:
  # Reconcile the internal admin account from the OpenBao-backed Secret on
  # every pod start. Database delivery changes happen only after PostgreSQL is
  # updated, then Reloader starts Gitea with both current credentials.
  podAnnotations:
    secret.reloader.stakater.com/reload: gitea-admin-secret,gitea-postgresql,gitea-encryption,gitea-runtime
  additionalConfigFromEnvs:
    - name: GITEA__DATABASE__PASSWD
      valueFrom:
        secretKeyRef:
          name: gitea-postgresql
          key: password
    - name: GITEA__security__SECRET_KEY
      valueFrom:
        secretKeyRef:
          name: gitea-encryption
          key: secret_key
    - name: GITEA__security__INTERNAL_TOKEN
      valueFrom:
        secretKeyRef:
          name: gitea-runtime
          key: internal_token
    - name: GITEA__server__LFS_JWT_SECRET
      valueFrom:
        secretKeyRef:
          name: gitea-runtime
          key: jwt_secret
    - name: GITEA__oauth2__JWT_SECRET
      valueFrom:
        secretKeyRef:
          name: gitea-runtime
          key: jwt_secret
  config:
    # Keep bootstrap on the single-node/local defaults. The bundled Valkey init
    # path has been failing before the gitea container starts, so avoid that
    # dependency entirely for the base install.
    cache:
      ADAPTER: memory
    session:
      PROVIDER: memory
    queue:
      TYPE: level
    server:
      DOMAIN: __GITEA_CANONICAL_HOST__
      ROOT_URL: __GITEA_ROOT_URL__
    oauth2:
      # A symmetric key makes OAuth signing state recoverable from OpenBao
      # instead of leaving an auto-generated private key only on the PVC.
      JWT_SIGNING_ALGORITHM: HS256
  admin:
    existingSecret: gitea-admin-secret
    passwordMode: keepUpdated

# Break-glass clusters are single-node initially. Keep the bootstrap install free
# of external cache/session/queue dependencies so a fresh ISO install can converge
# without waiting on bundled Valkey wiring.
valkey-cluster:
  enabled: false

valkey:
  enabled: false
